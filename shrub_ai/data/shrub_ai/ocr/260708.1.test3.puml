@startuml
!define kubectl "kubectl"
!define Resources "Resources (rc1, rc2)"
!define Service1 "Service1"
!define Service2 "Service2"
!define Minc Kube "Minc Kube"
!define profile "profile"
!define Image_repo "Image repo"
!define pod_man "pod man"
