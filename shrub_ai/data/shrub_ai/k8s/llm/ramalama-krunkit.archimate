    <element xsi:type="archimate:AccessRelationship" id="rel-otel-reads-config" source="elem-otel-collector" target="elem-otel-config"/>
    <element xsi:type="archimate:ServingRelationship" id="rel-logs-serves-otel" source="elem-host-logs" target="elem-otel-collector"/>
    <element xsi:type="archimate:AccessRelationship" id="rel-otel-scrapes-llama" source="elem-otel-collector" target="elem-llama-api"/>
    <element xsi:type="archimate:FlowRelationship" id="rel-llama-to-otel-svc" source="elem-llama-engine" target="elem-otel-service"/>
    <element xsi:type="archimate:FlowRelationship" id="rel-otel-to-jaeger" source="elem-otel-collector" target="elem-jaeger-endpoint"/>
  </folder>
