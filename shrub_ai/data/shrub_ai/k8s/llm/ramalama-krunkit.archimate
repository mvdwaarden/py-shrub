<?xml version="1.0" encoding="UTF-8"?>
<archimate:model xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xmlns:archimate="http://www.archimatetool.com/archimate" name="RamaLama Orchestrated AI Deployment Model" id="id-ramalama-k8s-architecture-model" version="5.0.0">
  <folder name="Strategy" id="id-c2c8ad96b39545d5958f350fd088bd5b" type="strategy"/>
  <folder name="Business" id="id-fea5f25b3b9647aeb0999a082bcdedef" type="business"/>
  <folder name="Application" id="id-547b026412ff42048cd729a7625266dd" type="application">
    <element xsi:type="archimate:ApplicationComponent" name="llama-engine (RamaLama)" id="elem-llama-engine">
      <documentation>llama-server processing engine with Vulkan-accelerated Venus driver translation logic.</documentation>
      <property key="Kubernetes Namespace" value="default"/>
      <property key="Container Image" value="quay.io/ramalama/ramalama:latest"/>
      <property key="Command Arguments" value="llama-server --host 0.0.0.0 --port 11434 --model /mnt/models/qwen2.5-vl-7b-instruct-q4_K_M.gguf -ngl 999 --threads 6"/>
      <property key="Environment Variables" value="LLAMA_ARG_ENDPOINT_METRICS=true, LLAMA_ARG_METRICS=true"/>
      <property key="Resource Request/Limits" value="devic.es/virtio-gpu: 1"/>
    </element>
    <element xsi:type="archimate:ApplicationComponent" name="OpenTelemetry Collector Contrib" id="elem-otel-collector">
      <documentation>Dynamic telemetry pipeline consolidating logs, scraping Prometheus context endpoints, and exporting OTLP streams.</documentation>
      <property key="Kubernetes Namespace" value="observability"/>
      <property key="Container Image" value="docker.io/otel/opentelemetry-collector-contrib:latest"/>
      <property key="Command Arguments" value="--config=/etc/otelcol-contrib/config.yaml"/>
    </element>
    <element xsi:type="archimate:ApplicationComponent" name="cert-manager Webhook" id="elem-cm-webhook">
      <documentation>Admission webhook verifying custom resources and injecting root-CA validation structures.</documentation>
      <property key="Kubernetes Namespace" value="cert-manager"/>
      <property key="Version / Tag" value="v1.16.1"/>
    </element>
    <element xsi:type="archimate:ApplicationComponent" name="cert-manager Controller" id="elem-cm-controller">
      <documentation>Core engine controller orchestrating cryptographic certificate generation and lifecycle verification.</documentation>
      <property key="Kubernetes Namespace" value="cert-manager"/>
      <property key="Version / Tag" value="v1.16.1"/>
    </element>
    <element xsi:type="archimate:ApplicationInterface" name="llama-server HTTP API" id="elem-llama-api">
      <documentation>Direct REST and model metrics interface endpoint.</documentation>
      <property key="Container Port" value="11434"/>
    </element>
  </folder>
  <folder name="Technology &amp; Physical" id="id-8571b53707bd4e01aed4356e5d7561e1" type="technology">
    <element xsi:type="archimate:Node" name="Minikube Virtual Host" id="elem-host-node">
      <documentation>Local QEMU/Hyperkit VM hypervisor representing the host node running on macOS (Apple Silicon).</documentation>
    </element>
    <element xsi:type="archimate:Device" name="virtio-gpu (Render Node)" id="elem-host-gpu">
      <documentation>Direct rendering manager (DRM) node passed down from the macOS host into the virtualized hypervisor.</documentation>
      <property key="Mounted Host Path / Port" value="/dev/dri/renderD128"/>
    </element>
    <element xsi:type="archimate:Path" name="Host Models Directory" id="elem-host-models">
      <documentation>Physical host path containing local GGUF/GGML models exposed via Minikube file-sharing.</documentation>
      <property key="Mounted Host Path / Port" value="/mnt/models"/>
    </element>
    <element xsi:type="archimate:Path" name="Host Container Logs Spool" id="elem-host-logs">
      <documentation>Direct mount path on the host VM filesystem containing output buffers from container standard out.</documentation>
      <property key="Mounted Host Path / Port" value="/var/log/pods"/>
    </element>
    <element xsi:type="archimate:Node" name="default Namespace" id="elem-ns-default">
      <documentation>Kubernetes boundary hosting core LLM workloads and application execution engines.</documentation>
    </element>
    <element xsi:type="archimate:Node" name="kube-system Namespace" id="elem-ns-kube-system">
      <documentation>Namespace holding hardware orchestration, drivers, and VM physical integrations.</documentation>
    </element>
    <element xsi:type="archimate:Node" name="observability Namespace" id="elem-ns-observability">
      <documentation>Logical segment containing log shippers, scrapers, and local diagnostic telemetry targets.</documentation>
    </element>
    <element xsi:type="archimate:Node" name="cert-manager Namespace" id="elem-ns-cert-manager">
      <documentation>Dynamic PKI validation controller and CA injector boundary.</documentation>
    </element>
    <element xsi:type="archimate:SystemSoftware" name="generic-device-plugin" id="elem-device-plugin">
      <documentation>DaemonSet scanning and exposing host render paths as schedulable virtual cluster GPU resources.</documentation>
      <property key="Kubernetes Namespace" value="kube-system"/>
      <property key="Container Image" value="squat/generic-device-plugin:latest"/>
      <property key="Resource Request/Limits" value="CPU: 50m, Memory: 10Mi (Requests) / 20Mi (Limits)"/>
    </element>
    <element xsi:type="archimate:Artifact" name="GGUF Model Weights" id="elem-gguf-weights">
      <documentation>Local quantized weights file loaded in system memory during engine boot sequence.</documentation>
      <property key="Command Arguments" value="qwen2.5-vl-7b-instruct-q4_K_M.gguf, Qwen2.5-VL-7B-Instruct-F16.gguf"/>
    </element>
    <element xsi:type="archimate:Artifact" name="OTel ConfigMap" id="elem-otel-config">
      <documentation>The pipeline settings YAML. Handles filelog tailing and pipelines to OTLP exporter destinations.</documentation>
      <property key="Kubernetes Namespace" value="observability"/>
      <property key="Version / Tag" value="otel-collector-conf"/>
    </element>
    <element xsi:type="archimate:TechnologyInterface" name="OTel Collector gRPC Receiver" id="elem-otel-grpc-port">
      <property key="Container Port" value="4317"/>
    </element>
    <element xsi:type="archimate:TechnologyInterface" name="OTel Collector HTTP Receiver" id="elem-otel-http-port">
      <property key="Container Port" value="4318"/>
    </element>
    <element xsi:type="archimate:TechnologyService" name="otel-collector Service" id="elem-otel-service">
      <documentation>Cluster Service routing internal workloads telemetry streams over gRPC and HTTP ports.</documentation>
      <property key="Kubernetes Namespace" value="observability"/>
    </element>
    <element xsi:type="archimate:TechnologyService" name="Host Jaeger Endpoint" id="elem-jaeger-endpoint">
      <documentation>Diagnostic host application acting as an external target for collector spans.</documentation>
      <property key="Mounted Host Path / Port" value="host.minikube.internal:4317"/>
    </element>
  </folder>
  <folder name="Motivation" id="id-177201c949294b179d83ba5aaf8f1f8c" type="motivation"/>
