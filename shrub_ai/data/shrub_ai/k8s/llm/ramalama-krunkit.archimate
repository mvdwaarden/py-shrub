    <element xsi:type="archimate:CompositionRelationship" id="rel-otel-composes-http" source="elem-otel-collector" target="elem-otel-http-port"/>
    <element xsi:type="archimate:RealizationRelationship" id="rel-svc-realizes-grpc" source="elem-otel-service" target="elem-otel-grpc-port"/>
