    <element xsi:type="archimate:AssignmentRelationship" id="rel-cm-ctrl-in-cm" source="elem-ns-cert-manager" target="elem-cm-controller"/>
    <element xsi:type="archimate:ServingRelationship" id="rel-host-gpu-serves-plugin" source="elem-host-gpu" target="elem-device-plugin"/>
